# Copy this file to deploy/kind/secrets/llm.env and fill in your provider keys.
# `up.sh` reads it via `kubectl create secret generic ... --from-env-file=...`.
# The keys are gitignored. Only the providers you actually use need values --
# leave the rest empty.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
